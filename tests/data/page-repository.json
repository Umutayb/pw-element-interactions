{
  "pages": [
    {
      "name": "DropDownPage",
      "elements": [
        {
          "elementName": "title",
          "selector": {
            "id": "title"
          }
        },
        {
          "elementName": "countriesDropDown",
          "selector": {
            "css": ".vs__search"
          }
        },
        {
          "elementName": "countriesContainer",
          "selector": {
            "css": "[role='listbox']"
          }
        },
        {
          "elementName": "countriesList",
          "selector": {
            "css": "#vs1__listbox .vs__dropdown-option"
          }
        },
        {
          "elementName": "selection",
          "selector": {
            "css": "#countriesDropDown .vs__selected"
          }
        }
      ]
    },
    {
      "name": "ElementsPage",
      "elements": [
        {
          "elementName": "pageTitle",
          "selector": {
            "css": "text:contains:Elements›Radio Buttons"
          }
        },
        {
          "elementName": "questionHeading",
          "selector": {
            "css": "h2"
          }
        },
        {
          "elementName": "yesRadio",
          "selector": {
            "css": "radio:has:Yes"
          }
        },
        {
          "elementName": "impressiveRadio",
          "selector": {
            "css": "radio:has:Impressive"
          }
        },
        {
          "elementName": "noRadio",
          "selector": {
            "css": "radio:has:No"
          }
        }
      ]
    },
